    "Q5": "┌─────────────────────────────────────┐\n│┌───────────────────────────────────┐│\n││    Query Profiling Information    ││\n│└───────────────────────────────────┘│\n└─────────────────────────────────────┘\n         EXPLAIN ANALYZE         WITH max_date AS (             SELECT MAX(timestamp) AS max_ts             FROM read_parquet('../ejercicio-01-formatos/data/transactions_1m_parquet_snappy.parquet')         )         SELECT             t.transaction_id,             t.timestamp,             t.user_id,             t.amount,             t.country_code         FROM read_parquet('../ejercicio-01-formatos/data/transactions_1m_parquet_snappy.parquet') t, max_date         WHERE t.amount > 500           AND t.country_code IN ('MX', 'CO')           AND t.timestamp >= max_date.max_ts - INTERVAL '30 days'         ORDER BY t.timestamp     \n┌────────────────────────────────────────────────┐\n│┌──────────────────────────────────────────────┐│\n││              Total Time: 0.0912s             ││\n│└──────────────────────────────────────────────┘│\n└────────────────────────────────────────────────┘\n┌───────────────────────────┐\n│           QUERY           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│      EXPLAIN_ANALYZE      │\n│    ────────────────────   │\n│                           │\n│           0 rows          │\n│           0.00s           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│         PROJECTION        │\n│    ────────────────────   │\n│             #0            │\n│             #1            │\n│__internal_decompress_integ│\n│     ral_bigint(#2, 1)     │\n│             #3            │\n│             #4            │\n│                           │\n│                           │\n│                           │\n│         9,883 rows        │\n│           0.00s           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│          ORDER_BY         │\n│    ────────────────────   │\n│     t.\"timestamp\"
    "Q3": "┌─────────────────────────────────────┐\n│┌───────────────────────────────────┐│\n││    Query Profiling Information    ││\n│└───────────────────────────────────┘│\n└─────────────────────────────────────┘\n         EXPLAIN ANALYZE         SELECT             user_id,             SUM(amount)  AS total_amount,             COUNT(*)     AS transaction_count         FROM read_parquet('../ejercicio-01-formatos/data/transactions_1m_parquet_snappy.parquet')         GROUP BY user_id         ORDER BY total_amount DESC         LIMIT 10     \n┌────────────────────────────────────────────────┐\n│┌──────────────────────────────────────────────┐│\n││              Total Time: 0.0883s             ││\n│└──────────────────────────────────────────────┘│\n└────────────────────────────────────────────────┘\n┌───────────────────────────┐\n│           QUERY           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│      EXPLAIN_ANALYZE      │\n│    ────────────────────   │\n│                           │\n│           0 rows          │\n│           0.00s           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│           TOP_N           │\n│    ────────────────────   │\n│          Top: 10          │\n│                           │\n│         Order By:         │\n│  sum(read_parquet.amount) │\n│            DESC           │\n│                           │\n│                           │\n│                           │\n│          10 rows          │\n│           0.00s           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│         PROJECTION        │\n│    ────────────────────   │\n│__internal_decompress_integ│\n│     ral_bigint(#0, 1)     │\n│             #1            │\n│             #2            │\n│                           │\n│                           │\n│                           │\n│        50,000 rows        │\n│           0.00s           │\n└─────────────┬─────────────┘\n┌─────────────┴─────────────┐\n│       HASH_GRO